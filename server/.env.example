# ─── Firebase Admin SDK ────────────────────────────────────────────────────────
# Download your service account key from:
# Firebase Console → Project Settings → Service Accounts → Generate new private key
# Then set the path here (never commit the actual JSON file)
FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json

# Or paste the JSON as a single-line string (for hosted environments):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ─── Encryption ────────────────────────────────────────────────────────────────
# Must be exactly 64 hex characters (32 bytes = 256-bit key)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AES_ENCRYPTION_KEY=your_64_char_hex_key_here

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Allowed frontend origin for CORS
CORS_ORIGIN=http://localhost:1235

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
